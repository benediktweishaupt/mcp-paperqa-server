{
  "name": "academic-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for academic research assistance with PDF processing and intelligent search",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/tools tests/errors tests/logging tests/protocol tests/middleware",
    "test:integration": "jest tests/integration",
    "test:mcp": "node scripts/test-mcp-integration.js",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write src/",
    "clean": "rm -rf dist/",
    "mcp:start": "./scripts/start-mcp-server.sh",
    "mcp:config": "echo 'Copy claude-desktop-config.json to ~/Library/Application Support/Claude/claude_desktop_config.json (macOS)'"
  },
  "keywords": [
    "mcp",
    "academic",
    "research",
    "pdf",
    "search",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@types/node": "^24.2.0",
    "express": "^5.1.0",
    "typescript": "^5.9.2",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2"
  }
}
