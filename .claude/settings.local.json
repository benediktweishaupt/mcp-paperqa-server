{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "MultiEdit",
      "Read",
      "Write",
      "WriteFile(*)",
      "ReadFile(*)",
      "CreateFile(*)",
      "DeleteFile(*)",
      "Glob",
      "Grep",
      "LS",
      "View",
      "WebFetch(*)",
      "WebSearch",
      "TodoRead",
      "TodoWrite",
      "Task",
      "mcp__*",
