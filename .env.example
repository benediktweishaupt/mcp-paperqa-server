# API Keys for Academic Research Assistant
# Copy this file to .env and fill in your actual keys

# OpenAI API Key (required for LLM operations)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Voyage AI API Key (REQUIRED — default embedding model)
# Get from: https://dash.voyageai.com/api-keys
# Fallback: change embedding to "text-embedding-3-small" in config.py
VOYAGE_API_KEY=your-voyage-api-key-here

# Optional: Other supported providers
# ANTHROPIC_API_KEY=your-anthropic-key-here
# GEMINI_API_KEY=your-gemini-key-here